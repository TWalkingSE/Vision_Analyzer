# ============================================
# Batch Image Analyzer - Environment Variables
# ============================================
# Copie este arquivo para .env e preencha suas chaves

# OpenAI API Key (obrigatório para GPT-5.4-mini)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Ollama (opcional - configure se usar servidor remoto)
# Por padrão, usa localhost:11434
# OLLAMA_HOST=http://localhost:11434
